#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

if ARCH_CHIP_STM32H7RS

comment "STM32H7RS Configuration Options"

choice
	prompt "STM32H7RS Chip Selection"
	default ARCH_CHIP_STM32H7S7L8
	depends on ARCH_CHIP_STM32H7RS

config ARCH_CHIP_STM32H7S7L8
	bool "STM32H7S7L8"
	select ARCH_CORTEXM7
	select ARMV7M_HAVE_ICACHE
	select ARMV7M_HAVE_DCACHE
	select ARMV7M_HAVE_ITCM
	select ARMV7M_HAVE_DTCM
	select ARMV7M_HAVE_STACKCHECK
	select STM32H7RS_STM32H7S7XX
	select STM32H7RS_FLASH_CONFIG_8
	---help---
		STM32H7RS Cortex-M7, 64 KiB internal FLASH, 456 KiB AXI SRAM.
		This is the device used by STM32H7S78-DK.

endchoice # STM32H7RS Chip Selection

config STM32H7RS_STM32H7S7XX
	bool
	default n
	select ARCH_HAVE_FPU

config STM32H7RS_FLASH_CONFIG_8
	bool
	default n

menu "STM32H7RS Peripheral Selection"

config STM32H7RS_USART
	bool "USART"
	default n
	---help---
		Enable STM32H7RS USART support once the low-level serial driver is
		ported.

config STM32H7RS_UART4_SERIALDRIVER
	bool "UART4 serial driver"
	default n
	depends on STM32H7RS_USART
	select UART4_SERIALDRIVER
	---help---
		Enable the STM32H7RS UART4 NuttX serial lower-half.  The
		STM32H7S78-DK uses UART4 on PD1/PD0 for its default console.

config STM32H7RS_GPIO
	bool "GPIO"
	default n
	---help---
		Enable STM32H7RS GPIO support once the GPIO register layer is
		ported.

config STM32H7RS_XSPI
	bool "XSPI"
	default n
	---help---
		Enable STM32H7RS XSPI support once the memory-mapped external
		flash/PSRAM path is ported.

config STM32H7RS_I2C
	bool "I2C"
	default n
	---help---
		Enable the STM32H7RS polling I2C master lower-half.

config STM32H7RS_I2C1
	bool "I2C1"
	default n
	depends on STM32H7RS_I2C
	---help---
		Enable I2C1.  The STM32H7S78-DK routes GT911 touch through PB6
		SCL and PB9 SDA.

config STM32H7RS_DISPLAY
	bool "LTDC display"
	default n
	---help---
		Enable the STM32H7RS LTDC framebuffer lower-half.

config STM32H7RS_LTDC_FB_DOUBLE_BUFFER
	bool "LTDC double framebuffer"
	default n
	depends on STM32H7RS_DISPLAY
	---help---
		Expose two vertically stacked framebuffer pages so LVGL's NuttX
		fbdev driver can use DIRECT render mode and FBIOPAN_DISPLAY.

endmenu # STM32H7RS Peripheral Selection

endif # ARCH_CHIP_STM32H7RS
