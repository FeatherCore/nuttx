if ARCH_CHIP_STM32N6

comment "STM32N6 Configuration Options"

config STM32N6_STM32N6XXXX
	bool
	default y

choice
	prompt "STM32 N6 Chip Selection"
	default ARCH_CHIP_STM32N657X0
	depends on ARCH_CHIP_STM32N6

config ARCH_CHIP_STM32N657X0
	bool "STM32N657X0"
	select STM32N6_STM32N6XXXX
	select ARCH_HAVE_RAMFUNCS
	select ARMV8M_HAVE_DCACHE
	select ARMV8M_HAVE_ICACHE
	---help---
		STM32N657 Cortex-M55 part used by STM32N6570-DK and
		NUCLEO-N657X0-Q.

endchoice

menu "STM32N6 Peripheral Selection"

config STM32N6_GPIO
	bool "GPIO"
	default n

config STM32N6_USART1
	bool "USART1"
	default n
	select STM32N6_USART
	select STM32N6_USART1_SERIALDRIVER
	select USART1_SERIALDRIVER

config STM32N6_USART
	bool "USART"
	default n

if STM32N6_USART

config STM32N6_USART1_SERIALDRIVER
	bool "USART1 serial driver"
	default n
	select ARCH_HAVE_SERIAL_TERMIOS
	select USART1_SERIALDRIVER
	---help---
		Enable the STM32N657 USART1 lower-half.

config STM32N6_SERIAL_DISABLE_REORDERING
	bool "Disable reordering of ttySx devices."
	depends on STM32N6_USART1
	default n
	---help---
		NuttX per default reorders the serial ports (/dev/ttySx) so that the
		console is always on /dev/ttyS0. If more than one UART is in use this
		can, however, have the side-effect that all port mappings
		(hardware USART1 -> /dev/ttyS0) change if the console is moved to
		another UART. This option disables that reordering so port names
		stay stable when the console is moved.

config STM32N6_FLOWCONTROL_BROKEN
	bool "Use Software UART RTS flow control"
	default n
	---help---
		Enable this option to use software RTS flow control rather than
		the hardware RTS line.  Useful in cases where the silicon RTS
		behaviour does not match the application's needs.

config STM32N6_SERIALBRK_BSDCOMPAT
	bool "Use GPIO to send Break"
	default n
	---help---
		Enable this option to send break by reconfiguring TX as a GPIO
		held low for the requested duration, matching BSD-compatible
		semantics.

config STM32N6_PM_SERIAL_ACTIVITY
	int "PM serial activity"
	default 10
	---help---
		PM activity reported to power management logic on every serial
		interrupt.

endif # STM32N6_USART

if USART1_SERIALDRIVER

config USART1_RXBUFSIZE
	int "USART1 receive buffer size"
	default 256

config USART1_TXBUFSIZE
	int "USART1 transmit buffer size"
	default 256

config USART1_UNCONFIG_RX_ON_CLOSE
	bool "Unconfigure USART1 RX pin on close"
	default n
	depends on STM32N6_USART1

config USART1_UNCONFIG_TX_ON_CLOSE
	bool "Unconfigure USART1 TX pin on close"
	default n
	depends on STM32N6_USART1

config STM32N6_USART1_TX_POLL_DRAIN
	bool "Drain USART1 TX buffer by polling"
	default n
	---help---
		Diagnostic option for early STM32N6 protected-mode bring-up.  When
		enabled, USART1 drains the software TX buffer synchronously when TX
		interrupts are enabled, instead of depending on later TXE/TXFNF
		interrupts to continue moving console output.

config STM32N6_USART1_HIGH_PRIORITY
	bool "Run USART1 at high IRQ priority"
	default n
	select ARCH_IRQPRIO
	---help---
		Diagnostic option for early STM32N6 protected-mode bring-up.  When
		enabled, USART1 uses NVIC_SYSH_HIGH_PRIORITY so console TX/RX IRQs
		are not masked by the normal BASEPRI critical-section threshold.

endif # USART1_SERIALDRIVER

config STM32N6_XSPI
	bool "XSPI"
	default n

config STM32N6_SDMMC
	bool "SDMMC"
	default n

config STM32N6_DISPLAY
	bool "Display controller block"
	default n

config STM32N6_GPU2D
	bool "GPU2D/NemaP"
	default n
	---help---
		Enable the STM32N6 GPU2D/NemaP low-level register and
		command-list backend.

config STM32N6_LTDC_FB_DOUBLE_BUFFER
	bool "LTDC framebuffer double buffering"
	default n
	depends on STM32N6_DISPLAY
	---help---
		Expose two screen-sized framebuffer pages through the NuttX
		framebuffer interface and switch the LTDC scanout address with
		FBIOPAN_DISPLAY.

config STM32N6_I2C
	bool "I2C"
	default n

config STM32N6_I2C2
	bool "I2C2"
	default n
	depends on STM32N6_I2C

config STM32N6_I2CTIMEO
	int "I2C poll timeout"
	default 2000000
	depends on STM32N6_I2C

config STM32N6_I2C2_TIMING
	hex "I2C2 TIMINGR value"
	default 0xe0b03c3d
	depends on STM32N6_I2C2
	---help---
		TIMINGR used by the minimal STM32N6 I2C2 master driver.
		The default matches the STM32CubeN6 timing algorithm for a
		200 MHz PCLK1 source and 100 kHz standard-mode bus.

endmenu

menu "STM32N6 Memory Attribute Configuration"

choice
	prompt "XSPI1 PSRAM MPU shareability"
	default STM32N6_PSRAM_MPU_SHARE_NONE
	depends on ARM_MPU
	---help---
		Select the ARMv8-M MPU shareability attribute used for the
		STM32N6 XSPI1 PSRAM memory-mapped window.  Cortex-M55 treats
		Shareable data transactions as Non-cacheable for the L1 data
		cache, so CPU-owned PSRAM heap and stack traffic must be mapped
		Non-shareable to benefit from the write-back cache policy.  PSRAM
		ranges shared with LTDC, DMA, or other bus masters still require
		explicit cache maintenance or a non-cacheable MPU override.

config STM32N6_PSRAM_MPU_SHARE_OUTER
	bool "Outer shareable"

config STM32N6_PSRAM_MPU_SHARE_NONE
	bool "Non-shareable"

endchoice

choice
	prompt "XSPI1 PSRAM MPU cache policy"
	default STM32N6_PSRAM_MPU_WRITE_BACK
	depends on ARM_MPU
	---help---
		Select the ARMv8-M MAIR cache attribute used for the STM32N6
		XSPI1 PSRAM memory-mapped window.

config STM32N6_PSRAM_MPU_WRITE_BACK
	bool "Write-back cacheable"

config STM32N6_PSRAM_MPU_WRITE_THROUGH
	bool "Write-through cacheable"

config STM32N6_PSRAM_MPU_NONCACHEABLE
	bool "Non-cacheable"

endchoice

config STM32N6_PSRAM_MPU_NO_WRITE_ALLOCATE
	bool "Use no-write-allocate cacheable MAIR for PSRAM"
	default y
	depends on ARM_MPU && !STM32N6_PSRAM_MPU_NONCACHEABLE
	---help---
		Use read-allocate, no-write-allocate MAIR encodings for the
		STM32N6 XSPI1 PSRAM MPU region.  This avoids the cacheable
		write-allocate linefill path and allows non-shareable cacheable
		PSRAM to be used for CPU-owned stack and heap traffic.  PSRAM
		regions shared with LTDC, DMA, or other bus masters still require
		a non-cacheable MPU override or explicit cache maintenance.

endmenu

endif # ARCH_CHIP_STM32N6
