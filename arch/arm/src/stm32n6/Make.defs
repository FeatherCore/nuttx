# Common ARM and Cortex-M55 files (ARMv8-M base)

include armv8-m/Make.defs

# The upstream STM32N6 port uses the common STM32-style stm32_* lower halves.
# STM32N6570-DK now shares the stm32_* GPIO, XSPI, LTDC, I2C, timer,
# console, start, RCC, heap and protected-mode helper paths.

ifeq ($(CONFIG_ARCH_BOARD_STM32N6570_DK),y)

CHIP_CSRCS += stm32_start.c
CHIP_CSRCS += stm32_rcc.c
CHIP_CSRCS += stm32_irq.c
CHIP_CSRCS += stm32_lowputc.c
CHIP_CSRCS += stm32_timerisr.c
CHIP_CSRCS += stm32_serial.c
CHIP_CSRCS += stm32_allocateheap.c

ifeq ($(CONFIG_BUILD_PROTECTED),y)
CHIP_CSRCS += stm32_userspace.c
CHIP_CSRCS += stm32_mpuinit.c
endif

ifeq ($(CONFIG_STM32N6_XSPI),y)
CHIP_CSRCS += stm32_xspi.c
endif

ifeq ($(CONFIG_STM32N6_GPIO),y)
CHIP_CSRCS += stm32_gpio.c
endif

ifeq ($(CONFIG_STM32N6_DISPLAY),y)
CHIP_CSRCS += stm32_ltdc.c
endif

ifeq ($(CONFIG_STM32N6_GPU2D),y)
CHIP_CSRCS += stm32_gpu2d.c
endif

ifeq ($(CONFIG_STM32N6_I2C),y)
CHIP_CSRCS += stm32_i2c.c
endif

else

# Required STM32N6 files

CHIP_CSRCS += stm32_gpio.c stm32_irq.c stm32_lowputc.c stm32_rcc.c
CHIP_CSRCS += stm32_start.c stm32_pwr.c stm32_timerisr.c

ifneq ($(CONFIG_ARCH_IDLE_CUSTOM),y)
CHIP_CSRCS += stm32_idle.c
endif

ifeq ($(CONFIG_STM32N6_USART),y)
CHIP_CSRCS += stm32_serial.c
endif

# Chip-specific RCC

CHIP_CSRCS += stm32n6xx_rcc.c

endif
