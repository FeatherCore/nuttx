#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

if ARCH_BOARD_STM32H7S78_DK

comment "STM32H7S78-DK Board Options"

config STM32H7RS_APP_FORMAT_NXBOOT
	bool "NXboot application image format"
	default n
	depends on STM32H7RS_XSPI
	select BOARDCTL_BOOT_IMAGE
	---help---
		Build an image intended to be managed by NXboot.  The board linker
		scripts place the loader in internal Flash and the application after
		an NXboot header in memory-mapped XSPI2 NOR.

config STM32H7RS_EXTNOR_OTA_PARTITION
	bool "Create OTA partitions on external NOR"
	default n
	depends on STM32H7RS_APP_FORMAT_NXBOOT
	select MTD
	select MTD_PARTITION
	---help---
		Register /dev/ota0, /dev/ota1 and /dev/ota2 from the
		STM32H7S78-DK XSPI2 NOR MTD.  Keep the partition table in
		Kconfig so NXboot slot geometry and board registration stay in
		sync.

config STM32H7RS_PSRAM_HEAP
	bool "Use XSPI1 PSRAM as an extra heap region"
	default n
	depends on STM32H7RS_XSPI && !NXBOOT_BOOTLOADER
	---help---
		Add the STM32H7S78-DK XSPI1 PSRAM at 0x90000000 to the NuttX heap
		from the board-specific arm_addregion() implementation.

config STM32H7RS_PSRAM_HEAP_OFFSET
	hex "XSPI1 PSRAM heap offset"
	default 0x00200000 if STM32H7S78_DK_LCD
	default 0x0
	depends on STM32H7RS_PSRAM_HEAP
	---help---
		Reserve the first bytes of the memory-mapped XSPI1 PSRAM window
		before adding the remaining range to the NuttX heap.  LCD-enabled
		configurations keep this area for the double-buffered framebuffer
		without overlapping malloc metadata or user allocations.

config STM32H7RS_PROTECTED_USRAM_BASE
	hex "Protected build user SRAM base"
	default 0x24060000
	depends on BUILD_PROTECTED
	---help---
		Base of the small internal SRAM window reserved for the protected
		build user blob .data/.bss sections.  The remaining internal SRAM
		below this address is available to the kernel heap.

config STM32H7RS_PROTECTED_USRAM_SIZE
	hex "Protected build user SRAM size"
	default 0x12000
	depends on BUILD_PROTECTED
	---help---
		Size of the protected build internal SRAM window reserved for user
		.data/.bss.  STM32H7S78-DK has 456 KiB AXI SRAM, so the default
		0x24060000..0x24071fff reserves 72 KiB for user static data and
		leaves the rest of internal SRAM for kernel state and kernel heap.

config STM32H7S78_DK_LCD
	bool "RK050HR18 RGB LCD framebuffer"
	default n
	depends on STM32H7RS_XSPI
	select DRIVERS_VIDEO
	select VIDEO_FB
	select FB_UPDATE
	select FB_SYNC
	select STM32H7RS_GPIO
	select STM32H7RS_DISPLAY
	select STM32H7RS_LTDC_FB_DOUBLE_BUFFER
	---help---
		Enable the STM32H7S78-DK 800x480 RK050HR18 RGB LCD through LTDC
		and expose the double-buffered RGB565 framebuffer as /dev/fb0.
		The framebuffer is placed at the start of XSPI1 PSRAM.

config STM32H7S78_DK_GT911
	bool "GT911 touchscreen"
	default n
	depends on STM32H7S78_DK_LCD
	select INPUT
	select INPUT_GT911
	select STM32H7RS_I2C
	select STM32H7RS_I2C1
	---help---
		Enable the Goodix GT911 touchscreen on /dev/input0.  The
		STM32H7S78-DK routes the touch controller through I2C1
		(PB6/PB9), matching the STM32CubeH7RS DK BSP.

config STM32H7S78_DK_GT911_POLL_MS
	int "GT911 poll interval in milliseconds"
	default 30
	depends on STM32H7S78_DK_GT911

config STM32H7S78_DK_GT911_DEBUG
	bool "GT911 touchscreen debug logs"
	default n
	depends on STM32H7S78_DK_GT911
	select INPUT_GT911_DEBUG

if STM32H7RS_EXTNOR_OTA_PARTITION

config STM32H7RS_OTA_PRIMARY_SLOT_DEVPATH
	string "Primary image slot devpath"
	default "/dev/ota0"

config STM32H7RS_OTA_SECONDARY_SLOT_DEVPATH
	string "Secondary image slot devpath"
	default "/dev/ota1"

config STM32H7RS_OTA_TERTIARY_SLOT_DEVPATH
	string "Tertiary image slot devpath"
	default "/dev/ota2"

config STM32H7RS_OTA_PRIMARY_SLOT_OFFSET
	hex "Primary image slot offset in external NOR"
	default 0x0

config STM32H7RS_OTA_SECONDARY_SLOT_OFFSET
	hex "Secondary image slot offset in external NOR"
	default 0x02000000

config STM32H7RS_OTA_TERTIARY_SLOT_OFFSET
	hex "Tertiary image slot offset in external NOR"
	default 0x04000000

config STM32H7RS_OTA_SLOT_SIZE
	hex "Image slot size"
	default 0x02000000

endif # STM32H7RS_EXTNOR_OTA_PARTITION

endif # ARCH_BOARD_STM32H7S78_DK
