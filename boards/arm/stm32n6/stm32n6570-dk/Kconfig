#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

if ARCH_BOARD_STM32N6570_DK

comment "STM32N6570-DK Board Options"

config STM32N6570_DK_NXBOOT_IMAGE
	bool "Build as BootROM-loaded NXboot payload"
	default n
	depends on NXBOOT_BOOTLOADER

config STM32N6_APP_FORMAT_NXBOOT
	bool "NXboot application image format"
	default n
	depends on STM32N6_XSPI
	select BOARDCTL_BOOT_IMAGE
	---help---
		Build an image managed by NXboot.  STM32N6570-DK places the
		NXboot payload in internal SRAM and XIP applications after an
		NXboot header in XSPI2 NOR.

config STM32N6_EXTNOR_OTA_PARTITION
	bool "Create OTA partitions on external NOR"
	default n
	depends on STM32N6_APP_FORMAT_NXBOOT
	select MTD
	select MTD_PARTITION
	---help---
		Register /dev/ota0, /dev/ota1 and /dev/ota2 from the
		STM32N6570-DK XSPI2 NOR MTD.  The first slot starts at
		0x70100000 because 0x70000000..0x700fffff is reserved for the
		BootROM header plus NXboot payload.

config STM32N6_EXTNOR_WRITE
	bool "Enable external NOR write/erase operations"
	default n
	depends on STM32N6_XSPI
	---help---
		Expose MX66UW1G45G erase and page program support through the
		STM32N6570-DK external NOR MTD.  Boot code never performs automatic
		write or erase; operations are only triggered by explicit file
		system or user commands.

config STM32N6_PSRAM_HEAP
	bool "Use XSPI1 PSRAM as an extra heap region"
	default n
	depends on STM32N6_XSPI && !NXBOOT_BOOTLOADER
	---help---
		App-side switch for adding STM32N6570-DK XSPI1 PSRAM at
		0x90000000 to the NuttX heap.  The heap starts after
		STM32N6_PSRAM_HEAP_OFFSET and extends to the end of PSRAM.

config STM32N6_PSRAM_HEAP_OFFSET
	hex "XSPI1 PSRAM heap offset"
	default 0x00200000 if STM32N6570_DK_LCD
	default 0x0 if BUILD_PROTECTED
	default 0x00200000
	depends on STM32N6_PSRAM_HEAP
	---help---
		Offset from 0x90000000 where the app-side PSRAM heap begins.
		LCD-enabled configurations keep the first 2 MiB free for the
		double-buffered framebuffer.  Non-LCD protected KNSh configurations
		use offset 0 when PSRAM is added as the secondary user heap region.
		LCD-enabled flat and protected configurations keep the first 2 MiB
		free for the framebuffer or early bring-up region.

config STM32N6_PROTECTED_USRAM_BASE
	hex "Protected build user SRAM base"
	default 0x341e0000
	depends on BUILD_PROTECTED
	---help---
		Base of the small internal SRAM window reserved for the protected
		build user blob .data/.bss sections.  The remaining internal SRAM
		below this address is available to the kernel heap.

config STM32N6_PROTECTED_USRAM_SIZE
	hex "Protected build user SRAM size"
	default 0x20000
	depends on BUILD_PROTECTED
	---help---
		Size of the protected build internal SRAM window reserved for user
		.data/.bss.  STM32N6570-DK currently gives the top 128 KiB of the
		2 MiB app SRAM window to user static data and leaves the rest of
		internal SRAM for kernel sections and kernel heap.

config STM32N6_PROTECTED_UHEAP_SIZE
	hex "Protected build bootstrap user heap size"
	default 0x2000 if STM32N6_PSRAM_HEAP && MM_KERNEL_HEAP
	default 0x0
	depends on BUILD_PROTECTED
	---help---
		Size of the initial protected user heap reserved inside the
		internal user SRAM window.  STM32N6570-DK protected builds keep
		the allocator control structure and earliest user allocations in
		internal SRAM, then add XSPI1 PSRAM later as an extra user heap
		region.  LCD/LVGL validation builds may raise this value to keep
		more hot UI allocations internal before the PSRAM heap is used.

config STM32N6570_DK_LCD
	bool "RK050HR18 RGB LCD framebuffer"
	default n
	depends on STM32N6_XSPI
	select DRIVERS_VIDEO
	select VIDEO_FB
	select FB_UPDATE
	select FB_SYNC
	select STM32N6_GPIO
	select STM32N6_DISPLAY
	select STM32N6_LTDC_FB_DOUBLE_BUFFER
	---help---
		Enable the STM32N6570-DK 800x480 RK050HR18 RGB panel through
		the LTDC block and expose it as /dev/fb0.  The double-buffered
		RGB565 framebuffer is placed at the start of XSPI1 PSRAM.

config STM32N6570_DK_GT911
	bool "GT911 touchscreen"
	default n
	depends on STM32N6570_DK_LCD
	select INPUT
	select INPUT_GT911
	select STM32N6_GPIO
	select STM32N6_I2C
	select STM32N6_I2C2
	---help---
		Enable the Goodix GT911 touchscreen on /dev/input0.  The DK
		wires GT911 to the LCD connector I2C2 pins (PD14 SCL, PD4 SDA)
		and PE1/PQ4 for reset/interrupt, matching the STM32CubeN6 DK BSP.

config STM32N6570_DK_GT911_POLL_MS
	int "GT911 poll interval in milliseconds"
	default 30
	depends on STM32N6570_DK_GT911

config STM32N6570_DK_GT911_DEBUG
	bool "GT911 touchscreen bring-up logs"
	default n
	depends on STM32N6570_DK_GT911
	select INPUT_GT911_DEBUG

if STM32N6_EXTNOR_OTA_PARTITION

config STM32N6_OTA_PRIMARY_SLOT_DEVPATH
	string "Primary image slot devpath"
	default "/dev/ota0"

config STM32N6_OTA_SECONDARY_SLOT_DEVPATH
	string "Secondary image slot devpath"
	default "/dev/ota1"

config STM32N6_OTA_TERTIARY_SLOT_DEVPATH
	string "Tertiary image slot devpath"
	default "/dev/ota2"

config STM32N6_OTA_PRIMARY_SLOT_OFFSET
	hex "Primary image slot offset in external NOR"
	default 0x00100000

config STM32N6_OTA_SECONDARY_SLOT_OFFSET
	hex "Secondary image slot offset in external NOR"
	default 0x02100000

config STM32N6_OTA_TERTIARY_SLOT_OFFSET
	hex "Tertiary image slot offset in external NOR"
	default 0x04100000

config STM32N6_OTA_SLOT_SIZE
	hex "Image slot size"
	default 0x02000000

endif # STM32N6_EXTNOR_OTA_PARTITION

config STM32N6570_DK_LCD_COLORBAR
	bool "Show LCD colorbar during bring-up"
	default n
	depends on STM32N6570_DK_LCD

endif # ARCH_BOARD_STM32N6570_DK
